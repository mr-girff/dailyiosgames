---
import Base from "../layouts/Base.astro"
import Subscribe from "../components/Subscribe.astro"
import Movers from "../components/Movers.astro"
import KeepBrowsing from "../components/KeepBrowsing.astro"
import fs from "node:fs"
import path from "node:path"

const dataPath = path.join(process.cwd(), "data/latest.json")
const data = fs.existsSync(dataPath)
  ? JSON.parse(fs.readFileSync(dataPath, "utf8"))
  : { date: "n/a", newReleases: [], updates: [] }

const enrichedPath = path.join(process.cwd(), "data/enriched.json")
const enriched = fs.existsSync(enrichedPath) ? JSON.parse(fs.readFileSync(enrichedPath, "utf8")) : { all: [] }
const byId = new Map(enriched.all.map(g => [g.id, g]))

// Merge enriched fields back into list
const newReleases = data.newReleases.map(g => ({ ...g, ...(byId.get(g.id) || {}) }))
const updates = data.updates.map(g => ({ ...g, ...(byId.get(g.id) || {}) }))

const SITE_NAME = import.meta.env.PUBLIC_SITE_NAME || "Daily iOS Games"
const tagline = "Every new game release & meaningful update on the US App Store, refreshed every morning."
const dateFmt = new Date(data.date + "T00:00:00Z").toLocaleDateString("en-US", { weekday: "long", month: "long", day: "numeric", year: "numeric", timeZone: "UTC" })

function cap(s){ return (s||"").replace(/(^|-)\w/g, c => c.toUpperCase()).replace(/-/g," ") }
function priceLabel(g){ const p = g.price; return (!p || p === "Free" || p === "0") ? "Free" : p }
---
<Base title={`${SITE_NAME} — Fresh US App Store Releases & Updates, Daily`} description={tagline}>
  <section class="hero-band hero-band--decorated">
    <svg class="hero-decor hero-decor--blob" viewBox="0 0 600 600" aria-hidden="true" focusable="false">
      <defs>
        <radialGradient id="heroBlob" cx=".5" cy=".5" r=".6">
          <stop offset="0" stop-color="#ffd3b8" stop-opacity=".85"/>
          <stop offset="1" stop-color="#ffd3b8" stop-opacity="0"/>
        </radialGradient>
      </defs>
      <circle cx="300" cy="300" r="280" fill="url(#heroBlob)"/>
    </svg>
    <svg class="hero-decor hero-decor--cards" viewBox="0 0 320 220" aria-hidden="true" focusable="false">
      <defs>
        <linearGradient id="cd1" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0" stop-color="#fff"/><stop offset="1" stop-color="#fde0d0"/>
        </linearGradient>
        <filter id="cardShadow" x="-20%" y="-20%" width="140%" height="140%">
          <feDropShadow dx="0" dy="4" stdDeviation="6" flood-color="#c15f3c" flood-opacity=".22"/>
        </filter>
      </defs>
      <g filter="url(#cardShadow)">
        <rect x="20" y="50" width="90" height="90" rx="22" fill="url(#cd1)" transform="rotate(-8 65 95)"/>
        <rect x="115" y="30" width="90" height="90" rx="22" fill="url(#cd1)"/>
        <rect x="210" y="60" width="90" height="90" rx="22" fill="url(#cd1)" transform="rotate(7 255 105)"/>
      </g>
      <g fill="#d97a4f">
        <circle cx="65" cy="95" r="14" transform="rotate(-8 65 95)"/>
        <circle cx="160" cy="75" r="14"/>
        <circle cx="255" cy="105" r="14" transform="rotate(7 255 105)"/>
      </g>
    </svg>

    <div class="hero-band__inner">
      <div class="eyebrow">{dateFmt}</div>
      <h1>{SITE_NAME}</h1>
      <p class="lead">{tagline}</p>

      <div class="stat-row">
        <div class="stat"><span class="num">{newReleases.length}</span><span class="lbl">New today</span></div>
        <div class="stat"><span class="num">{updates.length}</span><span class="lbl">Updates</span></div>
        <div class="stat"><span class="num">{enriched.all.length}</span><span class="lbl">Tracked total</span></div>
      </div>
    </div>

    <svg class="hero-wave" viewBox="0 0 1440 80" preserveAspectRatio="none" aria-hidden="true" focusable="false">
      <defs>
        <linearGradient id="hwg" x1="0" y1="0" x2="1" y2="0">
          <stop offset="0" stop-color="#f0a07b" stop-opacity="0"/>
          <stop offset=".5" stop-color="#f0a07b" stop-opacity=".55"/>
          <stop offset="1" stop-color="#f0a07b" stop-opacity="0"/>
        </linearGradient>
      </defs>
      <path d="M0,40 C240,80 480,0 720,40 C960,80 1200,0 1440,40 L1440,80 L0,80 Z" fill="url(#hwg)"/>
    </svg>
  </section>

  <Subscribe variant="hero" source="homepage-hero" />

  <Movers games={enriched.all} limit={12} />

  {newReleases.length > 0 && (
    <section>
      <div class="section-head">
        <h2>Today's new releases</h2>
        <a class="more" href="/games/">All games →</a>
      </div>
      <ul class="game-grid">
        {newReleases.slice(0, 1).map(g => (
          <li>
            <a class="game-card featured" href={`/games/${g.id}/`}>
              {g.icon && <img class="icon" src={g.images?.icon?.src || g.icon} alt={`${g.name} app icon`} width="96" height="96" loading="eager" />}
              <div class="meta">
                <div class="name">{g.name}</div>
                <div class="dev">{g.seller}</div>
                {(g.uniqueHook || g.coreLoop) && <p class="hook">{g.uniqueHook || g.coreLoop}</p>}
                <div class="tags">
                  {g.archetype && <span class="tag">{cap(g.archetype)}</span>}
                  <span class={`tag ${priceLabel(g)==='Free' ? 'price-free' : ''}`}>{priceLabel(g)}</span>
                  {g.verdict === "build" && <span class="tag signal">High signal</span>}
                </div>
              </div>
            </a>
          </li>
        ))}
        {newReleases.slice(1, 13).map(g => (
          <li>
            <a class="game-card" href={`/games/${g.id}/`}>
              {g.icon && <img class="icon" src={g.images?.icon?.src || g.icon} alt={`${g.name} app icon`} width="64" height="64" loading="lazy" />}
              <div class="meta">
                <div class="name">{g.name}</div>
                <div class="dev">{g.seller}</div>
                <div class="tags">
                  {g.archetype && <span class="tag">{cap(g.archetype)}</span>}
                  <span class={`tag ${priceLabel(g)==='Free' ? 'price-free' : ''}`}>{priceLabel(g)}</span>
                </div>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}

  {updates.length > 0 && (
    <section>
      <div class="section-head"><h2>Notable updates</h2></div>
      <ul class="update-list">
        {updates.slice(0, 10).map(g => (
          <li>
            {g.icon && <img class="icon" src={g.images?.icon?.src || g.icon} alt={`${g.name} app icon`} width="40" height="40" loading="lazy" />}
            <div class="ux">
              <a href={`/games/${g.id}/`}>{g.name}</a>
              <div class="when">v{g.version} · {g.seller}</div>
            </div>
            <span class="when">{g.daysSinceUpdate}d ago</span>
          </li>
        ))}
      </ul>
    </section>
  )}

  {/* Top-level "keep browsing" — invite deeper exploration before footer */}
  {(() => {
    const topArchetypes = [...new Set(enriched.all.map(g => g.archetype).filter(Boolean))]
      .map(a => ({ a, n: enriched.all.filter(g => g.archetype === a).length }))
      .sort((x, y) => y.n - x.n).slice(0, 4)
    const items = [
      { href: "/movers/",    title: "Rising games",    sub: "Hot momentum, ranked",   icon: "fire" },
      { href: "/posts/",     title: "Daily reports",   sub: "Every morning, the new releases", icon: "calendar" },
      { href: "/games/",     title: "All tracked games", sub: `${enriched.all.length} games & growing`, icon: "list" },
      ...topArchetypes.map(t => ({
        href: `/archetype/${t.a}/`,
        title: cap(t.a) + " games",
        sub: `${t.n} tracked`,
        icon: "tag",
      })),
    ].slice(0, 6)
    return <KeepBrowsing title="Keep exploring" eyebrow="Don't miss" items={items} />
  })()}

  <section>
    <p style="color:var(--fg-muted);font-size:.9rem;">
      <a href="/about/">About</a> · <a href="/methodology/">Methodology</a> · <a href="/rss.xml">RSS</a> · <a href="/api/data.json">Open data feed</a>
    </p>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context":"https://schema.org",
    "@type":"WebSite",
    "name": SITE_NAME,
    "url": Astro.site?.toString(),
    "description": tagline,
    "inLanguage": "en",
    "potentialAction": {
      "@type": "SearchAction",
      "target": `${(Astro.site?.toString() || "https://ios.querygame.com").replace(/\/$/, "")}/games/?q={search_term_string}`,
      "query-input": "required name=search_term_string"
    }
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context":"https://schema.org",
    "@type":"ItemList",
    "itemListOrder": "https://schema.org/ItemListOrderDescending",
    "name": `New iOS game releases — ${data.date}`,
    "numberOfItems": newReleases.length,
    "itemListElement": newReleases.slice(0, 12).map((g, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "url": `${(Astro.site?.toString() || "https://ios.querygame.com").replace(/\/$/, "")}/games/${g.id}/`,
      "name": g.name
    }))
  })} />
</Base>
