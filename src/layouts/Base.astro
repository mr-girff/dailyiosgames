---
const { title, description, canonical, robots = "index,follow", styleVars = "", bodyClass = "", image, ogType = "website" } = Astro.props
const ADSENSE = import.meta.env.PUBLIC_ADSENSE_CLIENT || "ca-pub-5723318931986381"
const GA_ID = import.meta.env.PUBLIC_GA_ID || "G-VCRWJW6CKF"
const site = Astro.site?.toString().replace(/\/$/, "") || "https://ios.querygame.com"
const SITE_NAME = import.meta.env.PUBLIC_SITE_NAME || "Daily iOS Games"
const ogImage = image || `${site}/og-default.svg`
const computedCanonical = canonical || `${site}${Astro.url.pathname}`
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <meta name="theme-color" content="#c15f3c" />
    <meta name="google-adsense-account" content={ADSENSE} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <link rel="canonical" href={computedCanonical} />
    <link rel="alternate" type="application/rss+xml" href="/rss.xml" title="Daily updates" />
    <link rel="alternate" type="application/rss+xml" href="/movers.xml" title="Rising iOS Games" />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={computedCanonical} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://pagead2.googlesyndication.com" crossorigin />
    <link rel="preconnect" href="https://www.googletagmanager.com" crossorigin />
    <link rel="stylesheet" href="/styles.css?v=20260628a" />

    {/* Google Analytics 4 */}
    {GA_ID && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>
        <script set:html={`
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', '${GA_ID}');
        `}></script>
      </>
    )}

    {/* Google AdSense */}
    {ADSENSE && (
      <script async src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${ADSENSE}`} crossorigin="anonymous"></script>
    )}

    {styleVars && <style set:html={`:root{${styleVars}}`}></style>}

    {/* Organization JSON-LD for richer SERP */}
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": SITE_NAME,
      "url": site,
      "logo": `${site}/favicon.svg`,
    })}></script>
  </head>
  <body class={`themed ${bodyClass}`}>
    <a href="#main" class="skip">Skip to content</a>
    <header class="site-header">
      <nav aria-label="Primary">
        <a href="/" class="brand" aria-label={SITE_NAME}>
          <svg class="brand-logo" width="32" height="32" viewBox="0 0 32 32" aria-hidden="true" focusable="false">
            <defs>
              <linearGradient id="brandg" x1="0" y1="0" x2="1" y2="1">
                <stop offset="0" stop-color="#f0a07b"/>
                <stop offset=".55" stop-color="#d97a4f"/>
                <stop offset="1" stop-color="#a8401f"/>
              </linearGradient>
              <radialGradient id="brandShine" cx=".3" cy=".25" r=".8">
                <stop offset="0" stop-color="#fff" stop-opacity=".55"/>
                <stop offset=".6" stop-color="#fff" stop-opacity="0"/>
              </radialGradient>
            </defs>
            <rect x="1" y="1" width="30" height="30" rx="8" fill="url(#brandg)"/>
            <rect x="1" y="1" width="30" height="30" rx="8" fill="url(#brandShine)"/>
            <path d="M6.5 21.5 L12.5 14.5 L16.5 18 L24.5 9" fill="none" stroke="#fff" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/>
            <circle cx="24.8" cy="9" r="2.7" fill="#fff"/>
          </svg>
          <span class="brand-name">{SITE_NAME}</span>
        </a>
        <button class="nav-toggle" type="button" aria-controls="primary-menu" aria-expanded="false" aria-label="Open menu">
          <svg class="nav-toggle__icon nav-toggle__icon--open" width="24" height="24" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
          <svg class="nav-toggle__icon nav-toggle__icon--close" width="24" height="24" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </button>
        <ul id="primary-menu">
          <li><a href="/posts/">Daily</a></li>
          <li><a href="/movers/">Rising</a></li>
          <li><a href="/games/">Games</a></li>
          <li><a href="/archetype/">Categories</a></li>
          <li><a href="/about/">About</a></li>
          <li><a href="/subscribe/" class="nav-cta">Subscribe</a></li>
        </ul>
      </nav>
    </header>
    <main id="main" class="site-main">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="foot-cols">
        <div class="foot-brand">
          <svg width="26" height="26" viewBox="0 0 32 32" aria-hidden="true">
            <rect x="1" y="1" width="30" height="30" rx="8" fill="#c15f3c"/>
            <path d="M6.5 21.5 L12.5 14.5 L16.5 18 L24.5 9" fill="none" stroke="#fff" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/>
            <circle cx="24.8" cy="9" r="2.7" fill="#fff"/>
          </svg>
          <span>{SITE_NAME}</span>
        </div>
        <nav class="foot-nav" aria-label="Footer">
          <a href="/movers/">Rising</a>
          <a href="/games/">Games</a>
          <a href="/archetype/">Categories</a>
          <a href="/posts/">Daily reports</a>
          <a href="/about/">About</a>
          <a href="/team/">Team</a>
          <a href="/methodology/">Methodology</a>
          <a href="/privacy/">Privacy</a>
          <a href="/rss.xml">RSS</a>
          <a href="/movers.xml">Rising RSS</a>
        </nav>
      </div>
      <p class="foot-fine">Data: Apple iTunes RSS &amp; Lookup APIs. Heat scores are our own estimates. Not affiliated with, endorsed by, or sponsored by Apple Inc. iOS and App Store are trademarks of Apple Inc.</p>
    </footer>

    {/* Floating "back to top" button — appears after scroll on mobile */}
    <button class="to-top" type="button" aria-label="Back to top">
      <svg width="22" height="22" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
        <path d="M12 19V5M5 12l7-7 7 7" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
      </svg>
    </button>

    <script is:inline>
      (function () {
        // Mobile hamburger menu
        var btn = document.querySelector(".nav-toggle");
        var menu = document.getElementById("primary-menu");
        var body = document.body;
        function close() {
          btn && btn.setAttribute("aria-expanded", "false");
          body.classList.remove("nav-open");
        }
        if (btn && menu) {
          btn.addEventListener("click", function () {
            var open = btn.getAttribute("aria-expanded") === "true";
            btn.setAttribute("aria-expanded", String(!open));
            body.classList.toggle("nav-open", !open);
          });
          // Close on link click
          menu.addEventListener("click", function (e) {
            if (e.target.tagName === "A") close();
          });
          // Close on Escape
          document.addEventListener("keydown", function (e) {
            if (e.key === "Escape") close();
          });
        }

        // Back-to-top + visibility
        var top = document.querySelector(".to-top");
        if (top) {
          var on = false;
          window.addEventListener("scroll", function () {
            var should = window.scrollY > 600;
            if (should !== on) {
              on = should;
              top.classList.toggle("to-top--visible", on);
            }
          }, { passive: true });
          top.addEventListener("click", function () {
            window.scrollTo({ top: 0, behavior: "smooth" });
          });
        }
      })();
    </script>
  </body>
</html>
