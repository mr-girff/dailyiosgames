---
import Base from "../../layouts/Base.astro"
import fs from "node:fs"
import path from "node:path"

export async function getStaticPaths() {
  const p = path.join(process.cwd(), "data/enriched.json")
  if (!fs.existsSync(p)) return []
  const data = JSON.parse(fs.readFileSync(p, "utf8"))
  const byArch = {}
  for (const g of data.all || []) (byArch[g.archetype] ||= []).push(g)
  return Object.entries(byArch).map(([archetype, games]) => ({ params: { archetype }, props: { archetype, games } }))
}
const { archetype, games } = Astro.props
const title = `${cap(archetype)} games on the US App Store`
const description = `${games.length} ${archetype} games tracked. Updated daily. Find new releases, recent updates, and what makes each one different.`
function cap(s){ return (s||"").replace(/(^|-)\w/g, c => c.toUpperCase()).replace(/-/g," ") }
---
<Base title={title} description={description} canonical={`${Astro.site}archetype/${archetype}/`}>
  <h1>{cap(archetype)} games</h1>
  <p class="lead">{description}</p>
  <ul>
    {games.sort((a,b)=>(b.signal||0)-(a.signal||0)).map(g => (
      <li>
        <a href={`/games/${g.id}/`}><strong>{g.name}</strong></a> — {g.seller}
        <small> · {g.sessionLength} · {g.monetization}{g.signal>=10?" · 🟢":""}</small>
      </li>
    ))}
  </ul>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context":"https://schema.org","@type":"CollectionPage",
    "name": title, "description": description,
    "mainEntity": { "@type":"ItemList", "numberOfItems": games.length,
      "itemListElement": games.slice(0,20).map((g,i)=>({ "@type":"ListItem","position":i+1,"name":g.name,"url":`${Astro.site}games/${g.id}/`}))
    }
  })} />
</Base>
