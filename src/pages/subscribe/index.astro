---
import Base from "../../layouts/Base.astro"
import Subscribe from "../../components/Subscribe.astro"
const SITE_NAME = import.meta.env.PUBLIC_SITE_NAME || "Daily iOS Games"
---
<Base
  title={`Subscribe — ${SITE_NAME}`}
  description="One email each morning with the day's new US App Store game releases and notable updates. Free, no spam, unsubscribe anytime."
  robots="noindex,follow"
>
  <section class="hero-band" style="border:0;padding-bottom:1rem;text-align:center;">
    <div class="eyebrow">Daily Newsletter</div>
    <h1>The new iOS games digest, every morning</h1>
    <p class="lead" style="margin: 1rem auto 0; max-width: 52ch;">
      Skip the App Store noise. Get a clean, structured rundown of yesterday's
      new US App Store game releases and meaningful updates — in under a minute, every day.
    </p>
  </section>

  <Subscribe variant="page" source="subscribe-page" />

  <section style="max-width:560px;margin:3rem auto 0;">
    <h2 style="font-size:1.3rem;">What you'll get</h2>
    <ul style="line-height:1.85; color:var(--fg-muted);">
      <li><strong style="color:var(--fg);">Every new game</strong> released yesterday in the US App Store, with developer, price, and genre at a glance.</li>
      <li><strong style="color:var(--fg);">Notable updates</strong> from games we track — only when something actually changed.</li>
      <li><strong style="color:var(--fg);">Editorial picks</strong> — 1–3 launches worth your attention, with our reasoning.</li>
      <li><strong style="color:var(--fg);">Plain text, no images.</strong> Reads in 60 seconds. Works on every email client.</li>
    </ul>

    <h2 style="font-size:1.3rem; margin-top:2.5rem;">Who reads this</h2>
    <p style="color:var(--fg-muted);">
      iOS indie developers tracking competitor launches · game studios scouting trends ·
      mobile-game investors · writers and journalists covering the App Store ·
      curious players who want first-mover discovery.
    </p>

    <h2 style="font-size:1.3rem; margin-top:2.5rem;">Building something with our data?</h2>
    <p style="color:var(--fg-muted);">
      Need <strong style="color:var(--fg);">historical snapshots</strong>,
      <strong style="color:var(--fg);">webhook notifications</strong> when games matching your filter launch,
      <strong style="color:var(--fg);">CSV exports</strong>, or
      <strong style="color:var(--fg);">higher API rate limits</strong>?
      We're considering a paid tier — <a href="mailto:hello@dailyiosgames.com?subject=Paid%20data%20access&body=I%27d%20be%20interested%20in:%20%5Bhistorical%20data%20/%20webhooks%20/%20CSV%20/%20other%5D%0A%0AWhat%20I%27m%20building:%20%0A%0AWhat%20I%27d%20be%20willing%20to%20pay:%20" style="font-weight:500;">email us what you'd want and what you'd pay</a>.
      Real responses shape what we build next.
    </p>

    <h2 style="font-size:1.3rem; margin-top:2.5rem;">No spam, ever</h2>
    <p style="color:var(--fg-muted);">
      One email per day, sent around 8am ET. Unsubscribe with one click in every email.
      We never share or sell your email. See our
      <a href="/about/">about page</a> for who we are.
    </p>
  </section>
</Base>
