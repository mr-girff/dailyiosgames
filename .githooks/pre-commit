#!/usr/bin/env bash
# =============================================================================
# .githooks/pre-commit — MODEL-AGNOSTIC work-trace logger
# -----------------------------------------------------------------------------
# Runs on every `git commit`, regardless of which agent/model produced the
# changes (Claude, GPT, Grok, a human, or any tool). This is the tool-agnostic
# fallback layer that complements Claude Code's .claude/ PostToolUse hook.
#
# What it does:
#   * Reads the STAGED diff (what is about to be committed).
#   * Appends a dated entry per changed file to docs/work-trace/trace-log.md,
#     mirroring the format of .claude/hooks/log-trace.sh.
#   * Re-stages the updated trace log so it lands in the SAME commit.
#
# Model attribution:
#   * Set TRACE_MODEL=gpt|grok|claude|<name> before committing to tag the
#     source model. If unset, defaults to "unknown".
#     e.g.  TRACE_MODEL=gpt git commit -m "..."
#
# Safety:
#   * Never blocks the commit (always exits 0), even on internal error.
#   * Skips itself when committing produces no staged file changes.
#   * Guard TRACE_SKIP=1 to bypass entirely (e.g. automated data commits).
# =============================================================================
set -uo pipefail

[ "${TRACE_SKIP:-0}" = "1" ] && exit 0

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "$REPO_ROOT" 2>/dev/null || exit 0

TRACE_DIR="docs/work-trace"
TRACE_LOG="$TRACE_DIR/trace-log.md"
MODEL="${TRACE_MODEL:-unknown}"
NOW_UTC="$(date -u +'%Y-%m-%d %H:%M:%S UTC')"
DAY_UTC="$(date -u +'%Y-%m-%d')"

# Files staged for this commit (added/copied/modified/renamed), excluding the
# trace log itself to avoid a feedback loop.
mapfile -t FILES < <(git diff --cached --name-only --diff-filter=ACMR 2>/dev/null \
  | grep -vxF "$TRACE_LOG" || true)

# Nothing meaningful staged → nothing to trace.
[ "${#FILES[@]}" -eq 0 ] && exit 0

mkdir -p "$TRACE_DIR"

# Ensure header + today's date section exist.
if [ ! -f "$TRACE_LOG" ]; then
  {
    echo "# Work Trace Log"
    echo
    echo "> Auto-generated by the work-trace hooks (Git \`pre-commit\` + Claude Code \`PostToolUse\`)."
    echo "> Every file modification is recorded below, grouped by UTC date."
    echo "> **Do not edit by hand** — entries are append-only."
    echo
  } >> "$TRACE_LOG"
fi
if ! grep -qxF "## $DAY_UTC" "$TRACE_LOG" 2>/dev/null; then
  { echo "## $DAY_UTC"; echo; } >> "$TRACE_LOG"
fi

# Write one entry per staged file.
for REL in "${FILES[@]}"; do
  [ -z "$REL" ] && continue

  STATUS="modified"
  # If the path is not in HEAD, it's newly added in this commit.
  if ! git cat-file -e "HEAD:$REL" >/dev/null 2>&1; then
    STATUS="created"
  fi

  ADDED=0; REMOVED=0
  NUMSTAT="$(git diff --cached --numstat -- "$REL" 2>/dev/null | head -n1)"
  if [ -n "$NUMSTAT" ]; then
    ADDED="$(printf '%s'  "$NUMSTAT" | cut -f1)"
    REMOVED="$(printf '%s' "$NUMSTAT" | cut -f2)"
  fi
  [ "$ADDED"   = "-" ] && ADDED="(binary)"
  [ "$REMOVED" = "-" ] && REMOVED="(binary)"

  DIFF_BODY="$(git diff --cached -- "$REL" 2>/dev/null \
    | grep -E '^[+-]' \
    | grep -vE '^(\+\+\+|---)' \
    | head -n 12)"

  {
    echo "### \`$REL\` — $STATUS"
    echo
    echo "- **When:** $NOW_UTC"
    echo "- **Source:** git commit (model: $MODEL)"
    echo "- **Change size:** +$ADDED / -$REMOVED lines"
    echo "- **What:** $STATUS \`$REL\`."
    echo "- **How:** staged change captured at commit time by the model-agnostic pre-commit hook."
    echo "- **Note:** treated as 0% hand-written code; review the diff before merging."
    if [ -n "$DIFF_BODY" ]; then
      echo
      echo "<details><summary>Key diff (truncated)</summary>"
      echo
      echo '```diff'
      printf '%s\n' "$DIFF_BODY"
      echo '```'
      echo
      echo "</details>"
    fi
    echo
  } >> "$TRACE_LOG"
done

# Re-stage the trace log so it's part of THIS commit.
git add "$TRACE_LOG" 2>/dev/null || true

exit 0
