---
import Base from "../layouts/Base.astro"
import GameGrid from "../components/GameGrid.astro"
import KeepBrowsing from "../components/KeepBrowsing.astro"
import { isControllerSupported } from "../lib/format"
import fs from "node:fs"
import path from "node:path"

const p = path.join(process.cwd(), "data/enriched.json")
const data = fs.existsSync(p) ? JSON.parse(fs.readFileSync(p, "utf8")) : { all: [], date: "n/a" }
const all = data.all || []

const list = all.filter(isControllerSupported)
  .sort((a, b) => (b.signal || 0) - (a.signal || 0))

// Bucket by archetype for browseability
const byArch: Record<string, any[]> = {}
for (const g of list) {
  const a = g.archetype || "other"
  if (!byArch[a]) byArch[a] = []
  byArch[a].push(g)
}
const archOrder = Object.entries(byArch).sort((a, b) => b[1].length - a[1].length).map(([k]) => k)

const dateFmt = data.date
  ? new Date(data.date + "T00:00:00Z").toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric", timeZone: "UTC" })
  : ""

function cap(s: string) { return (s || "").replace(/(^|-)\w/g, c => c.toUpperCase()).replace(/-/g, " ") }

const SITE_NAME = import.meta.env.PUBLIC_SITE_NAME || "Daily iOS Games"
const canonical = `${(Astro.site || "").toString().replace(/\/$/, "")}/controller-support/`
const ogImg = `${(Astro.site || "").toString().replace(/\/$/, "")}/hero-controller.svg`

const title = `iOS Games With Controller Support — Verified ${dateFmt}`
const description = `${list.length} iOS games that explicitly support MFi controllers, Bluetooth gamepads, Backbone One and PlayStation/Xbox pads. Verified from App Store metadata daily by ${SITE_NAME}.`
---
<Base title={title} description={description} canonical={canonical} image={ogImg}>
  <section class="hero-band hero-band--decorated dark">
    <img class="hero-decor hero-decor--blob" src="/hero-controller.svg" alt="" width="600" height="600" aria-hidden="true" />
    <div class="hero-band__inner">
      <div class="eyebrow">Updated {dateFmt} · verified from App Store text</div>
      <h1>iOS Games With Controller Support</h1>
      <p class="lead">Touch controls are fine. A real pad is better. Every game on this page explicitly mentions controller, gamepad or Backbone support in its App Store metadata — no guessing, no manual lists that go stale.</p>
      <div class="stat-row">
        <div class="stat"><span class="num">{list.length}</span><span class="lbl">Games found</span></div>
        <div class="stat"><span class="num">{archOrder.length}</span><span class="lbl">Categories</span></div>
        <div class="stat"><span class="num">{all.length}</span><span class="lbl">Tracked total</span></div>
      </div>
    </div>
  </section>

  {list.length > 0 ? (
    <>
      <section>
        <div class="section-head"><h2>Top controller-ready picks</h2></div>
        <GameGrid games={list.slice(0, 12)} featuredFirst={true} eagerCount={2} />
      </section>

      {archOrder.map(arch => (
        <section>
          <div class="section-head">
            <h2>{cap(arch)}</h2>
            <span class="more">{byArch[arch].length} game{byArch[arch].length === 1 ? "" : "s"}</span>
          </div>
          <GameGrid games={byArch[arch]} />
        </section>
      ))}
    </>
  ) : (
    <p class="empty-state">No games in the current cohort explicitly advertise controller support. Check back as new releases are tracked daily.</p>
  )}

  <section class="prose">
    <h2>How "controller support" is verified</h2>
    <p>Each tracked game's App Store description, "what's new" notes and core-loop summary are scanned for explicit controller-related phrases: <code>controller support</code>, <code>MFi controller</code>, <code>gamepad support</code>, <code>Backbone</code>, <code>Xbox controller</code>, <code>PlayStation controller</code>, <code>DualSense</code>, <code>DualShock</code>. If a phrase appears, the game lands here. If a developer adds the claim in a future update, it appears on the next morning's refresh.</p>
    <p>This avoids the two failure modes of every other "iOS controller games" list:</p>
    <ul>
      <li><strong>Stale curation.</strong> Hand-built lists rot. The minute a game drops support in v3.2, no one updates the blog post.</li>
      <li><strong>Inferred claims.</strong> "It's an RPG so it probably supports a controller" — except it doesn't. We only count explicit, on-page claims.</li>
    </ul>
    <h3>Compatible hardware</h3>
    <p>iOS 13+ natively supports Xbox Wireless, DualSense, DualShock 4 and all MFi-certified pads (PlayStation Portal, Backbone One, GameSir, 8BitDo, etc.). If the game advertises "controller support," it works with the modern Apple controller framework — no app-specific pairing required.</p>
    <h3>Related pages</h3>
    <ul>
      <li><a href="/offline/">Offline iOS games</a> — perfect for Backbone-on-a-flight</li>
      <li><a href="/no-iap/">No in-app purchases</a> — console-style premium games</li>
      <li><a href="/movers/">Rising iOS games</a> — what's getting hot right now</li>
    </ul>
  </section>

  {(() => {
    const items = [
      { href: "/offline/", title: "Offline games", sub: "Backbone on a flight", icon: "tag" },
      { href: "/no-iap/", title: "No in-app purchases", sub: "Pay-once games", icon: "star" },
      { href: "/hidden-gems/", title: "Hidden gems", sub: "Indies worth a controller", icon: "star" },
      { href: "/movers/", title: "Rising games", sub: "Hot momentum", icon: "fire" },
      { href: "/new-today/", title: "New today", sub: "Fresh launches", icon: "calendar" },
      { href: "/games/", title: "All tracked games", sub: `${all.length} titles`, icon: "list" },
    ]
    return <KeepBrowsing title="Keep exploring" eyebrow="More" items={items} />
  })()}

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": title,
    "description": description,
    "url": canonical,
    "datePublished": data.date,
    "dateModified": data.date,
    "mainEntity": {
      "@type": "ItemList",
      "name": "iOS Games With Controller Support",
      "numberOfItems": list.length,
      "itemListOrder": "https://schema.org/ItemListOrderDescending",
      "itemListElement": list.slice(0, 25).map((g, i) => ({
        "@type": "ListItem",
        "position": i + 1,
        "name": g.name,
        "url": `${(Astro.site || "").toString().replace(/\/$/, "")}/games/${g.id}/`
      }))
    }
  })} />
</Base>

<style>
  .prose { margin-top: 2.5rem; max-width: 72ch; }
  .prose h2 { margin-top: 1.75rem; }
  .prose h3 { margin-top: 1.25rem; font-size: 1.1rem; }
  .prose ul { padding-left: 1.25rem; }
  .empty-state { padding: 2rem 1rem; text-align: center; color: var(--fg-muted); background: var(--muted); border-radius: 14px; }
</style>
