---
import Base from "../../layouts/Base.astro"
import GameGrid from "../../components/GameGrid.astro"
import KeepBrowsing from "../../components/KeepBrowsing.astro"
import { SEEDS } from "../../lib/likeSeeds"
import type { LikeSeed } from "../../lib/likeSeeds"
import fs from "node:fs"
import path from "node:path"

export async function getStaticPaths() {
  const p = path.join(process.cwd(), "data/enriched.json")
  const data = fs.existsSync(p) ? JSON.parse(fs.readFileSync(p, "utf8")) : { all: [], date: "n/a" }
  const all = data.all || []

  return SEEDS.map(seed => {
    // Score each candidate game vs. this seed.
    function score(g: any): number {
      let s = 0
      const text = `${g.name || ""} ${g.desc || ""} ${g.coreLoop || ""} ${g.uniqueHook || ""}`.toLowerCase()
      // Skip the seed itself if it's in our tracked set.
      if (g.name && g.name.toLowerCase().includes(seed.name.toLowerCase())) return -1
      // Archetype match
      if (seed.archetypes.includes(g.archetype)) s += 6
      // Tag match
      for (const t of (seed.tags || [])) if ((g.tags || []).includes(t)) s += 3
      // Keyword hits
      for (const kw of seed.keywords) if (text.includes(kw.toLowerCase())) s += 4
      // Exclusions
      for (const kw of (seed.excludeKeywords || [])) if (text.includes(kw.toLowerCase())) s -= 10
      // Quality boost
      if (g.verdict === "build") s += 3
      if (g.verdict === "watch") s += 1
      if ((g.signal || 0) >= 12) s += 2
      // Rating gate (don't surface low-quality matches)
      const r = Number(g.rating || 0)
      if (r > 0 && r < 3.5) s -= 4
      return s
    }

    const ranked = all
      .map((g: any) => ({ g, s: score(g) }))
      .filter((x: any) => x.s >= 6)
      .sort((a: any, b: any) => b.s - a.s)
      .map((x: any) => x.g)

    return {
      params: { seed: seed.slug },
      props: { seed, matches: ranked, date: data.date, allCount: all.length },
    }
  })
}

interface Props {
  seed: LikeSeed
  matches: any[]
  date: string
  allCount: number
}
const { seed, matches, date, allCount } = Astro.props as Props

const top = matches.slice(0, 12)
const more = matches.slice(12, 36)

const dateFmt = date
  ? new Date(date + "T00:00:00Z").toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric", timeZone: "UTC" })
  : ""

const SITE_NAME = import.meta.env.PUBLIC_SITE_NAME || "Daily iOS Games"
const canonical = `${(Astro.site || "").toString().replace(/\/$/, "")}/like/${seed.slug}/`
const ogImg = `${(Astro.site || "").toString().replace(/\/$/, "")}/hero-like.svg`

const title = seed.longTitle
const description = seed.metaDescription
---
<Base title={title} description={description} canonical={canonical} image={ogImg}>
  <nav class="crumbs"><a href="/">Home</a> › <a href="/like/">Games like…</a> › {seed.name}</nav>

  <section class="hero-band hero-band--decorated">
    <img class="hero-decor hero-decor--blob" src="/hero-like.svg" alt="" width="600" height="600" aria-hidden="true" />
    <div class="hero-band__inner">
      <div class="eyebrow">Updated {dateFmt} · {matches.length} matches found</div>
      <h1>iOS Games Like {seed.name}</h1>
      <p class="lead">{seed.blurb}</p>
      <div class="stat-row">
        <div class="stat"><span class="num">{matches.length}</span><span class="lbl">Matches</span></div>
        <div class="stat"><span class="num">{seed.archetypes.length}</span><span class="lbl">Categories</span></div>
        <div class="stat"><span class="num">{allCount}</span><span class="lbl">Tracked total</span></div>
      </div>
    </div>
  </section>

  {top.length > 0 ? (
    <section>
      <div class="section-head">
        <h2>Top picks if you loved {seed.name}</h2>
        <span class="more">Ranked by similarity</span>
      </div>
      <GameGrid games={top} featuredFirst={true} eagerCount={2} />
    </section>
  ) : (
    <p class="empty-state">No strong matches in the current tracked cohort. We re-rank every morning — check back tomorrow.</p>
  )}

  {more.length > 0 && (
    <section>
      <div class="section-head">
        <h2>More games like {seed.name}</h2>
        <span class="more">{more.length} more</span>
      </div>
      <GameGrid games={more} />
    </section>
  )}

  <section class="prose">
    <h2>What makes a game "like {seed.name}"?</h2>
    <ul>
      {seed.whatMakesItLikeThis.map(item => <li>{item}</li>)}
    </ul>
    <h3>How matches are ranked</h3>
    <p>Each tracked iOS game is scored against {seed.name} using four signals:</p>
    <ul>
      <li><strong>Archetype overlap</strong> — does the game live in the same broad genre family ({seed.archetypes.join(", ")})?</li>
      <li><strong>Keyword overlap</strong> — does the App Store description name the core mechanics?</li>
      {seed.tags && seed.tags.length > 0 && <li><strong>Tag overlap</strong> — are the same lifestyle tags present ({seed.tags.join(", ")})?</li>}
      <li><strong>Quality floor</strong> — App Store rating must be ≥ 3.5; editorial-flagged picks get a boost.</li>
    </ul>
    <p>The scoring runs against the live US App Store cohort every morning. Games that drop in quality or get pulled fall off this page automatically.</p>
    <h3>Related "games like" pages</h3>
    <ul>
      {SEEDS.filter(s => s.slug !== seed.slug).slice(0, 6).map(s => (
        <li><a href={`/like/${s.slug}/`}>iOS games like {s.name}</a></li>
      ))}
    </ul>
  </section>

  {(() => {
    const items = [
      { href: "/like/", title: "All 'games like…' pages", sub: "Find by inspiration", icon: "tag" },
      { href: "/hidden-gems/", title: "Hidden gems", sub: "Indies worth a shot", icon: "star" },
      { href: "/movers/", title: "Rising games", sub: "Hot momentum", icon: "fire" },
      { href: "/new-today/", title: "New today", sub: "Fresh launches", icon: "calendar" },
      ...seed.archetypes.slice(0, 2).map(a => ({
        href: `/archetype/${a}/`,
        title: a.replace(/-/g, " ") + " category",
        sub: "Browse the whole archetype",
        icon: "list",
      })),
    ].slice(0, 6)
    return <KeepBrowsing title="Keep exploring" eyebrow="More" items={items} />
  })()}

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": title,
    "description": description,
    "url": canonical,
    "datePublished": date,
    "dateModified": date,
    "mainEntity": {
      "@type": "ItemList",
      "name": `iOS Games Like ${seed.name}`,
      "numberOfItems": matches.length,
      "itemListOrder": "https://schema.org/ItemListOrderDescending",
      "itemListElement": matches.slice(0, 20).map((g: any, i: number) => ({
        "@type": "ListItem",
        "position": i + 1,
        "name": g.name,
        "url": `${(Astro.site || "").toString().replace(/\/$/, "")}/games/${g.id}/`
      }))
    },
    "breadcrumb": {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": (Astro.site || "").toString() },
        { "@type": "ListItem", "position": 2, "name": "Games like", "item": `${(Astro.site || "").toString().replace(/\/$/, "")}/like/` },
        { "@type": "ListItem", "position": 3, "name": seed.name, "item": canonical }
      ]
    }
  })} />
</Base>

<style>
  .crumbs { font-size: .85rem; color: var(--fg-muted); margin-bottom: 1rem; }
  .crumbs a { color: var(--fg-muted); }
  .prose { margin-top: 2.5rem; max-width: 72ch; }
  .prose h2 { margin-top: 1.75rem; }
  .prose h3 { margin-top: 1.25rem; font-size: 1.1rem; }
  .prose ul { padding-left: 1.25rem; }
  .prose li { margin: .25rem 0; }
  .empty-state { padding: 2rem 1rem; text-align: center; color: var(--fg-muted); background: var(--muted); border-radius: 14px; }
</style>
