---
import Base from "../../layouts/Base.astro"
import Hero from "../../components/Hero.astro"
import TrendSparkline from "../../components/TrendSparkline.astro"
import Reviews from "../../components/Reviews.astro"
import fs from "node:fs"
import path from "node:path"

export async function getStaticPaths() {
  const p = path.join(process.cwd(), "data/enriched.json")
  if (!fs.existsSync(p)) return []
  const data = JSON.parse(fs.readFileSync(p, "utf8"))
  return (data.all || []).map(g => ({ params: { id: g.id }, props: { game: g, all: data.all } }))
}

const { game, all } = Astro.props
const robots = game.indexDirective || "index,follow"
const canonical = `${Astro.site || ""}games/${game.id}/`.replace(/\/+/g,"/").replace(":/","://")

const similar = (game.similar || []).map(s => all.find(g => g.id === s.id)).filter(Boolean).slice(0, 6)
const sameStudio = all.filter(g => g.id !== game.id && g.seller === game.seller).slice(0, 4)

const title = `${game.name} — ${capitalize(game.archetype)} game by ${game.seller}`
const description = oneLine(`${game.name} is a ${game.archetype} game by ${game.seller}. ${game.uniqueHook || game.coreLoop || ""} Latest version ${game.version} (${game.currentVersionDate}). Rating ${game.rating || "n/a"} from ${game.ratingCount || 0} reviews.`)

function oneLine(s){ return (s||"").replace(/\s+/g," ").trim().slice(0, 240) }
function capitalize(s){ return (s||"").replace(/(^|-)\w/g, c => c.toUpperCase()).replace(/-/g," ") }
---
<Base
  title={title}
  description={description}
  canonical={canonical}
  robots={robots}
  image={game.icon}
  bodyClass={`theme-${game.archetype}`}
>
  <nav class="crumbs" aria-label="Breadcrumb">
    <a href="/">Home</a> › <a href={`/archetype/${game.archetype}/`}>{capitalize(game.archetype)}</a> › <span>{game.name}</span>
  </nav>

  <Hero game={game} />

  {game.video?.mp4 && (
    <section>
      <h2>15-second look</h2>
      <video controls preload="none" poster={game.video.poster} width="540" height="960" playsinline>
        <source src={game.video.mp4} type="video/mp4" />
      </video>
      <p class="caveat">Auto-generated montage of the developer's official screenshots with synthesized narration. Not actual gameplay footage.</p>
    </section>
  )}

  <p class="tldr"><strong>TL;DR</strong><br/>{description}</p>

  {game.trends && (
    <section>
      <h2>Search interest</h2>
      <TrendSparkline trend={game.trends} />
    </section>
  )}

  <section>
    <h2>What kind of game this is</h2>
    <dl class="facts">
      <div><dt>Genre</dt><dd>{(game.genres || []).join(", ") || "Games"}</dd></div>
      <div><dt>Core loop</dt><dd>{game.coreLoop || "—"}</dd></div>
      <div><dt>Typical session</dt><dd>{game.sessionLength || "—"}</dd></div>
      <div><dt>Built for</dt><dd>{game.audience || "—"}</dd></div>
      <div><dt>Monetization</dt><dd>{game.monetization || "—"}</dd></div>
      {game.tags?.length > 0 && <div><dt>Features</dt><dd>{game.tags.join(" · ")}</dd></div>}
    </dl>
  </section>

  {game.uniqueHook && (
    <section>
      <h2>What stands out</h2>
      <blockquote>{game.uniqueHook}</blockquote>
    </section>
  )}

  {game.redFlags?.length > 0 && (
    <section>
      <h2>Things to watch out for</h2>
      <ul>{game.redFlags.map(f => <li>{f}</li>)}</ul>
      <p class="caveat">Observations based on official App Store metadata; verify in-game before purchasing.</p>
    </section>
  )}

  {game.releaseNotes && (
    <section>
      <h2>What's new in v{game.version}</h2>
      <p class="meta">Released {game.currentVersionDate} ({game.daysSinceUpdate}d ago)</p>
      <pre class="release-notes">{game.releaseNotes}</pre>
    </section>
  )}

  <section>
    <h2>About {game.name}</h2>
    <div class="desc">{game.desc}</div>
  </section>

  {similar.length > 0 && (
    <section>
      <h2>Similar {capitalize(game.archetype)} games</h2>
      <ul class="link-grid">
        {similar.map(s => <li><a href={`/games/${s.id}/`}>{s.name}</a><small>{s.seller}</small></li>)}
      </ul>
    </section>
  )}

  {sameStudio.length > 0 && (
    <section>
      <h2>More from {game.seller}</h2>
      <ul class="link-grid">
        {sameStudio.map(s => <li><a href={`/games/${s.id}/`}>{s.name}</a></li>)}
      </ul>
    </section>
  )}

  <Reviews gameId={game.id} gameName={game.name} />

  <section class="cta-block">
    <h2 style="margin-top:0">Download {game.name}</h2>
    <a class="cta" href={game.url} rel="nofollow noopener" target="_blank">Open on the App Store →</a>
  </section>

  <section>
    <h2>FAQ</h2>
    <details><summary>Is {game.name} free?</summary><p>{game.price === "Free" || !game.price ? `Yes — free to download. Monetization model: ${game.monetization || "unknown"}.` : `It costs ${game.price}.`}</p></details>
    <details><summary>How long is a typical play session?</summary><p>{game.sessionLength || "Varies by player."}</p></details>
    <details><summary>Does {game.name} work offline?</summary><p>{game.tags?.includes("offline") ? "Yes, it supports offline play." : "Apple's listing does not explicitly mention offline support; an internet connection may be required."}</p></details>
    <details><summary>When was the last update?</summary><p>Version {game.version} was released on {game.currentVersionDate}, {game.daysSinceUpdate} day(s) ago.</p></details>
  </section>

  {game.video?.mp4 && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context":"https://schema.org","@type":"VideoObject",
      "name": `${game.name} — 15-second look`,
      "description": `Auto-generated visual montage of ${game.name} with narrated overview.`,
      "thumbnailUrl": (Astro.site||"") + game.video.poster.replace(/^\//,""),
      "uploadDate": new Date().toISOString().slice(0,10),
      "duration": "PT15S",
      "contentUrl": (Astro.site||"") + game.video.mp4.replace(/^\//,""),
      "publisher": { "@type":"Organization", "name": import.meta.env.PUBLIC_SITE_NAME || "Daily Games" }
    })} />
  )}
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context":"https://schema.org","@type":"VideoGame",
    "name": game.name,
    "applicationCategory":"GameApplication",
    "operatingSystem":"iOS",
    "genre": game.genres,
    "softwareVersion": game.version,
    "datePublished": game.releaseDate,
    "url": canonical,
    "image": game.icon,
    "publisher": { "@type":"Organization", "name": game.seller },
    "offers": { "@type":"Offer", "price": game.price === "Free" ? "0" : (game.price || "").replace(/[^\d.]/g,"") || "0", "priceCurrency":"USD", "url": game.url },
    ...(game.ratingCount ? { "aggregateRating": { "@type":"AggregateRating", "ratingValue": game.rating, "ratingCount": game.ratingCount }} : {}),
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context":"https://schema.org","@type":"BreadcrumbList",
    "itemListElement":[
      { "@type":"ListItem","position":1,"name":"Home","item": (Astro.site||"") + "" },
      { "@type":"ListItem","position":2,"name": capitalize(game.archetype), "item": (Astro.site||"") + `archetype/${game.archetype}/` },
      { "@type":"ListItem","position":3,"name": game.name, "item": canonical },
    ]
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context":"https://schema.org","@type":"FAQPage",
    "mainEntity":[
      { "@type":"Question","name":`Is ${game.name} free?`, "acceptedAnswer":{ "@type":"Answer","text": game.price === "Free" || !game.price ? `Yes — free to download.` : `It costs ${game.price}.`}},
      { "@type":"Question","name":"How long is a typical play session?", "acceptedAnswer":{"@type":"Answer","text": game.sessionLength || "Varies."}},
      { "@type":"Question","name": `Does ${game.name} work offline?`, "acceptedAnswer":{"@type":"Answer","text": game.tags?.includes("offline") ? "Yes." : "Apple's listing does not explicitly mention offline support."}},
      { "@type":"Question","name":"When was the last update?", "acceptedAnswer":{"@type":"Answer","text": `Version ${game.version} on ${game.currentVersionDate}.`}},
    ]
  })} />
</Base>
