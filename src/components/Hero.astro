---
// Unified hero: prominent app icon + name + dev + hook + key facts.
// Falls back gracefully when screenshots are missing.
import { appStoreUrl } from "../lib/appstore"
const { game } = Astro.props
const storeUrl = appStoreUrl(game)
const icon = game.images?.icon?.src || game.icon
const shots = Array.isArray(game.screenshots) ? game.screenshots.filter(Boolean) : []
const price = game.price === "Free" || game.price === "0" ? "Free" : (game.price || "Free")
function cap(s){ return (s||"").replace(/(^|-)\w/g, c => c.toUpperCase()).replace(/-/g," ") }
---
<section class="detail-hero">
  {icon && (
    <img class="icon-xl" src={icon} alt={`${game.name} app icon`} width="168" height="168" fetchpriority="high" loading="eager" />
  )}
  <div>
    <h1>{game.name}</h1>
    <p class="seller">by {game.seller}</p>

    <div class="pill-row">
      {game.archetype && <span class="pill primary">{cap(game.archetype)}</span>}
      <span class="pill">{price}</span>
      {game.sessionLength && <span class="pill">{game.sessionLength}</span>}
      {game.rating > 0 && <span class="pill">★ {game.rating.toFixed(1)} · {game.ratingCount}</span>}
    </div>

    {(game.uniqueHook || game.coreLoop) && (
      <p class="hook">{game.uniqueHook || game.coreLoop}</p>
    )}

    <a class="cta" href={storeUrl} rel="nofollow noopener" target="_blank">
      View on App Store →
    </a>
  </div>
</section>

{shots.length > 0 && (
  <section>
    <h2>Screenshots</h2>
    <div class="gallery" role="list">
      {shots.slice(0, 8).map((s, i) => (
        <picture role="listitem">
          <img src={s} alt={`${game.name} screenshot ${i+1}`} width="400" height="600"
               loading={i === 0 ? "eager" : "lazy"}
               fetchpriority={i === 0 ? "high" : "auto"} />
        </picture>
      ))}
    </div>
  </section>
)}
