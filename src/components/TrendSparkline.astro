---
// Tiny inline SVG sparkline. Server-rendered. No JS.
const { trend } = Astro.props
if (!trend?.points?.length) return null
const w = 280, h = 60, pad = 4
const pts = trend.points
const max = Math.max(...pts.map(p => p.v), 1)
const stepX = (w - pad*2) / (pts.length - 1 || 1)
const path = pts.map((p, i) => {
  const x = pad + i * stepX
  const y = h - pad - (p.v / max) * (h - pad*2)
  return `${i === 0 ? "M" : "L"}${x.toFixed(1)},${y.toFixed(1)}`
}).join(" ")
const lastY = h - pad - (pts[pts.length-1].v / max) * (h - pad*2)
const lastX = pad + (pts.length-1) * stepX
const trendLabel = trend.slopePct > 15 ? "rising" : trend.slopePct < -15 ? "declining" : "stable"
---
<figure class="spark">
  <svg viewBox={`0 0 ${w} ${h}`} role="img" aria-label={`Google Trends search interest, ${trendLabel} (${trend.slopePct >= 0 ? '+' : ''}${trend.slopePct}% vs prior 8 weeks)`}>
    <path d={path} fill="none" stroke="var(--accent)" stroke-width="2" stroke-linejoin="round" stroke-linecap="round" />
    <circle cx={lastX.toFixed(1)} cy={lastY.toFixed(1)} r="3" fill="var(--accent)" />
  </svg>
  <figcaption>
    Google Trends · last 3 months · {trendLabel}
    <strong style={`color:${trend.slopePct>=0?'#5cd685':'#e07070'}`}>
      {trend.slopePct >= 0 ? "+" : ""}{trend.slopePct}%
    </strong>
  </figcaption>
</figure>
<style>
.spark { margin: .75rem 0; }
.spark svg { width: 100%; max-width: 280px; height: auto; background: var(--muted); border-radius: 8px; padding: 4px; }
.spark figcaption { font-size: .75rem; opacity: .8; margin-top: .25rem; }
</style>
