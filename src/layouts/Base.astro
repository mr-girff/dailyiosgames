---
const { title, description, canonical, robots = "index,follow", styleVars = "", bodyClass = "", image, ogType = "website" } = Astro.props
const ADSENSE = import.meta.env.PUBLIC_ADSENSE_CLIENT
const site = Astro.site?.toString().replace(/\/$/, "") || ""
const ogImage = image || `${site}/og-default.png`
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    {canonical && <link rel="canonical" href={canonical} />}
    <link rel="alternate" type="application/rss+xml" href="/rss.xml" title="Daily updates" />
    <link rel="alternate" type="application/rss+xml" href="/movers.xml" title="Rising iOS Games" />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    {canonical && <meta property="og:url" content={canonical} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="/styles.css" />
    {ADSENSE && (
      <script async src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${ADSENSE}`} crossorigin="anonymous" data-loadafter="3000"></script>
    )}
    {styleVars && <style set:html={`:root{${styleVars}}`}></style>}
  </head>
  <body class={`themed ${bodyClass}`}>
    <a href="#main" class="skip">Skip to content</a>
    <header class="site-header">
      <nav aria-label="Primary">
        <a href="/" class="brand" aria-label={import.meta.env.PUBLIC_SITE_NAME || "Daily iOS Games"}>
          <svg class="brand-logo" width="30" height="30" viewBox="0 0 32 32" aria-hidden="true" focusable="false">
            <defs>
              <linearGradient id="brandg" x1="0" y1="0" x2="1" y2="1">
                <stop offset="0" stop-color="#d97a4f"/>
                <stop offset="1" stop-color="#b34a2a"/>
              </linearGradient>
            </defs>
            <rect x="1" y="1" width="30" height="30" rx="8" fill="url(#brandg)"/>
            <path d="M6.5 21.5 L12.5 14.5 L16.5 18 L24.5 9" fill="none" stroke="#fff" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/>
            <circle cx="24.8" cy="9" r="2.7" fill="#fff"/>
          </svg>
          <span class="brand-name">{import.meta.env.PUBLIC_SITE_NAME || "Daily iOS Games"}</span>
        </a>
        <ul>
          <li><a href="/posts/">Daily</a></li>
          <li><a href="/movers/">Rising</a></li>
          <li><a href="/games/">Games</a></li>
          <li><a href="/archetype/">Categories</a></li>
          <li><a href="/about/">About</a></li>
          <li><a href="/subscribe/" style="color:var(--accent-ink); font-weight:500;">Subscribe</a></li>
        </ul>
      </nav>
    </header>
    <main id="main" class="site-main">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="foot-cols">
        <div class="foot-brand">
          <svg width="26" height="26" viewBox="0 0 32 32" aria-hidden="true">
            <rect x="1" y="1" width="30" height="30" rx="8" fill="#c15f3c"/>
            <path d="M6.5 21.5 L12.5 14.5 L16.5 18 L24.5 9" fill="none" stroke="#fff" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/>
            <circle cx="24.8" cy="9" r="2.7" fill="#fff"/>
          </svg>
          <span>{import.meta.env.PUBLIC_SITE_NAME || "Daily iOS Games"}</span>
        </div>
        <nav class="foot-nav" aria-label="Footer">
          <a href="/movers/">Rising</a>
          <a href="/games/">Games</a>
          <a href="/archetype/">Categories</a>
          <a href="/posts/">Daily reports</a>
          <a href="/about/">About</a>
          <a href="/team/">Team</a>
          <a href="/methodology/">Methodology</a>
          <a href="/privacy/">Privacy</a>
          <a href="/rss.xml">RSS</a>
          <a href="/movers.xml">Rising RSS</a>
        </nav>
      </div>
      <p class="foot-fine">Data: Apple iTunes RSS &amp; Lookup APIs. Heat scores are our own estimates. Not affiliated with, endorsed by, or sponsored by Apple Inc. iOS and App Store are trademarks of Apple Inc.</p>
    </footer>
  </body>
</html>
